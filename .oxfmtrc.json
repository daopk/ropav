{
  "$schema": "./node_modules/oxfmt/configuration_schema.json",
  "printWidth": 100,
  "tabWidth": 2,
  "singleQuote": true,
  "semi": true,
  "trailingComma": "all",
  "sortPackageJson": false,
  "ignorePatterns": [
    "dist/**",
    "storybook-static/**",
    "src/styles/_tokens.scss",
    "src/styles/_variables.scss"
  ],
  "overrides": [
    {
      "files": ["**/*.{js,mjs,cjs,ts,mts,cts,tsx,vue,scss}"],
      "options": {
        "tabWidth": 4
      }
    }
  ]
}
