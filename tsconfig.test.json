{
  "extends": "./tsconfig.app.json",
  "compilerOptions": {
    "tsBuildInfoFile": "./node_modules/.tmp/tsconfig.test.tsbuildinfo",
    "allowJs": true,
    "paths": {
      "@/*": ["./src/*"],
      "ropav/unplugin-icons": ["./src/unplugin-icons.ts"]
    },
    "types": ["vite/client", "vitest", "node", "unplugin-icons/types/vue"],
    "noEmit": true
  },
  "include": [
    "src/**/*.test.ts",
    "src/**/*.test.tsx",
    "src/**/*.spec.ts",
    "src/**/*.spec.tsx",
    "tests/**/*.ts",
    "tests/**/*.tsx"
  ],
  "exclude": ["node_modules", "dist", "tests/fixtures/consumer-types"]
}
